    "html2canvas": "^1.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-zoom-pan-pinch": "^4.0.3",
